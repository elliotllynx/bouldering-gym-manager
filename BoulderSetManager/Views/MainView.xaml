<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BoulderSetManager.ViewModels"
             xmlns:entities="clr-namespace:BoulderSetManager.Models.Entities"
             x:Class="BoulderSetManager.Views.MainView"
             Shell.NavBarIsVisible="False"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui">

    <ContentPage.BindingContext>
        <vm:MainViewModel/>
    </ContentPage.BindingContext>

    <Grid>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto">

            <!-- Row 0: Gym Selection -->
            <HorizontalStackLayout Grid.Row="0" Padding="16,0" >
                <Button Grid.Column="0" Text="← Back"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}"/>
                <BoxView WidthRequest="1" 
                         Margin="10"
                         BackgroundColor="Gray" 
                         VerticalOptions="Fill"/>
                <Label Grid.Column="1" Text="Gym:"
                       VerticalOptions="Center"
                       Padding="10,0,0,0"/>
                <Label Grid.Column="1" Text="{Binding SelectedGym.DisplayName}"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       Padding="10,0,0,0"/>

            </HorizontalStackLayout>

            <!-- Row 1: Filtering -->
            <HorizontalStackLayout Grid.Row="1" Padding="16,0">
                <Label Text="Filter Boulders:"
                           VerticalOptions="Center"
                           Padding="15,0,15,0"/>

                <Button Text="{Binding SelectedWallsSummary}"
                        Command="{Binding ToggleWallListCommand}"
                        BackgroundColor="Turquoise"
                        TextColor="Black"
                        CornerRadius="6"
                        Margin="15,0,0,0"/>

                <Label Text="Grade:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterGrade}"
                           Placeholder="e.g. 6A"
                           WidthRequest="80"/>

                <Label Text="Style:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Picker ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding FilterStyle}"
                            WidthRequest="100"/>

                <Label Text="Author:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterAuthor}"
                           Placeholder="Author"
                           WidthRequest="100"/>

                <Label Text="Retire in &lt;= "
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterRetireInDays}"
                           Placeholder="days"
                           Keyboard="Numeric"
                           WidthRequest="60"/>
                <Label Text="days"
                           VerticalOptions="Center"/>

                <Button Text="Filter"
                        BackgroundColor="Turquoise"
                        TextColor="Black"
                        CornerRadius="6"
                        Margin="15,0,0,0"
                        Command="{Binding FilterCommand}"/>
                <Button Text="Reset"
                        BackgroundColor="#444"
                        TextColor="White"
                        CornerRadius="6"
                        Margin="5,0,0,0"
                        Command="{Binding ResetFilterCommand}"/>
                <Button Text="Filter Soon Retiring Boulders"
                        BackgroundColor="#444"
                        TextColor="White"
                        CornerRadius="6"
                        Margin="5,0,0,0"
                        Command="{Binding FilterRetiringCommand}"/>

            </HorizontalStackLayout>



            <!-- Row 2: Error Message -->
            <Label Grid.Row="2" 
                   Text="{Binding FilterErrorMessage}" 
                   TextColor="Red" FontSize="12"
                   IsVisible="{Binding HasFilterError}"
                   Padding="15"/>

            <!-- Row 4: Column Annotations -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*,*,*,*,*"
                  Margin="20,5,160,3">
                <Label Grid.Column="0" Text="Grade" TextColor="Gray" FontSize="12"/>
                <Label Grid.Column="1" Text="Type" TextColor="Gray" FontSize="12"/>
                <Label Grid.Column="2" Text="Author" TextColor="Gray" FontSize="12"/>
                <Label Grid.Column="3" Text="Days Left" TextColor="Gray" FontSize="12"/>
                <Label Grid.Column="4" Text="Built" TextColor="Gray" FontSize="12"/>
                <Label Grid.Column="5" Text="Retire" TextColor="Gray" FontSize="12"/>
            </Grid>

            <!-- Row 4: Boulder List View -->
            <ScrollView Grid.Row="4"
                        VerticalScrollBarVisibility="Always">

                <!-- Following CollectionView xaml made with the help of ClaudeAI -->
                <CollectionView ItemsSource="{Binding Walls}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="entities:WallDTO">
                            <VerticalStackLayout Padding="12,8" IsVisible="{Binding IsVisible}">

                                <!-- Wall header -->
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                      BackgroundColor="#2a2a2a"
                                      Padding="12,8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                    <Button Grid.Column="1"
                                            Text="+ Boulder"
                                            BackgroundColor="Turquoise"
                                            TextColor="Black"
                                            CornerRadius="6"
                                            Margin="10,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowAddBoulderCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="2"
                                            Text="Edit"
                                            BackgroundColor="#444"
                                            TextColor="White"
                                            CornerRadius="6"
                                            Margin="10,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowEditWallCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="3"
                                            Text="Delete"
                                            BackgroundColor="#c0392b"
                                            TextColor="White"
                                            CornerRadius="6"
                                            Margin="10,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteWallCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>

                                <!-- Boulder rows -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Boulders}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="entities:BoulderProblemDTO">
                                            <Grid ColumnDefinitions="2*,2*,2*,2*,2*,2*,0.8*,1.2*,*"
                                                  Padding="12,2"
                                                  BackgroundColor="{Binding RowColor}"
                                                  IsVisible="{Binding IsVisible}">
                                                <Label Grid.Column="0" Text="{Binding Grade}" TextColor="White"/>
                                                <Label Grid.Column="1" Text="{Binding Style}" TextColor="White"/>
                                                <Label Grid.Column="2" Text="{Binding Author}" TextColor="White"/>
                                                <Label Grid.Column="3" Text="{Binding DaysLeft, StringFormat='{0} days'}"/>
                                                <Label Grid.Column="4" Text="{Binding BuiltDate, StringFormat='{0:dd.MM.yy}'}" TextColor="White"/>
                                                <Label Grid.Column="5" Text="{Binding RetireDate, StringFormat='{0:dd.MM.yy}'}" TextColor="White"/>
                                                <Border Grid.Column="6" 
                                                        HeightRequest="30"
                                                        VerticalOptions="Center"
                                                        Margin="0,0,10,0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="6"/>
                                                    </Border.StrokeShape>
                                                    <Label  Text="Edit"
                                                            TextColor="#aaa"
                                                            VerticalOptions="Center"
                                                            HorizontalOptions="Center"
                                                            Padding="10,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowEditBoulderCommand}"
                                                                    CommandParameter="{Binding .}"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </Border>
                                                <Border Grid.Column="7" 
                                                        HeightRequest="30"
                                                        VerticalOptions="Center"
                                                        Stroke="DarkGoldenrod"
                                                        Margin="0,0,10,0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="6"/>
                                                    </Border.StrokeShape>
                                                    <Label  Text="{Binding ArchivedButtonText}"
                                                            TextColor="DarkGoldenrod"
                                                            VerticalOptions="Center"
                                                            HorizontalOptions="Center"
                                                            Padding="10,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ToggleArchiveBoulderCommand}"
                                                                    CommandParameter="{Binding .}"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </Border>
                                                <Border Grid.Column="8" 
                                                        HeightRequest="30"
                                                        VerticalOptions="Center"
                                                        Stroke="DarkRed"
                                                        Margin="0,0,10,0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="6"/>
                                                    </Border.StrokeShape>
                                                    <Label  Text="Delete"
                                                            TextColor="DarkRed"
                                                            VerticalOptions="Center"
                                                            HorizontalOptions="Center"
                                                            Padding="10,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteBoulderCommand}"
                                                                    CommandParameter="{Binding }"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

            <microcharts:ChartView Grid.Row="4"
                                   WidthRequest="100"
                                   HeightRequest="100"
                                   HorizontalOptions="End"
                                   VerticalOptions="End"
                                   Margin="12"
                                   Chart="{Binding StyleChart}"/>

            <Grid Grid.Row="5" ColumnDefinitions="*,*" >
                <HorizontalStackLayout HorizontalOptions="Start" Grid.Column="0" Padding="15,0">
                    <Label Text="Active" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding ActiveVisible}" />

                    <Label Text="Draft" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding DraftVisible}" />

                    <Label Text="Archived" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding ArchivedVisible}" />
                </HorizontalStackLayout >
                <HorizontalStackLayout HorizontalOptions="End" Margin="20,3,20,0" Grid.Column="1">
                    <Label Text="Average Grade:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                    <Label Text="{Binding AverageGrade}"
                           FontAttributes="Bold"
                           FontSize="20"
                           VerticalOptions="Center"
                           Padding="5,0,15,0"/>
                    <BoxView Color="#00FFFF" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" Margin="5,0"/>
                    <Label Text="Slab" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                    <BoxView Color="#FF00FF" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"  Margin="5,0"/>
                    <Label Text="Vertical" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                    <BoxView Color="#FFFF00" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"  Margin="5,0"/>
                    <Label Text="Overhang" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- Row 6: Add wall button -->
            <Button Grid.Row="6"
                    Text="+ Add Wall"
                    BackgroundColor="Turquoise"
                    CornerRadius="8"
                    Margin="16"
                    WidthRequest="200"
                    HorizontalOptions="Start"
                    Command="{Binding ShowAddWallCommand}"/>
        </Grid>

        <BoxView Color="Black"
                 Opacity="0.5"
                 IsVisible="{Binding IsPopUpVisible}" />

        <!-- Select Walls Pop Up -->
        <Border IsVisible="{Binding IsWallListExpanded}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="350"
                Padding="24"
                BackgroundColor="White"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout >
                <CollectionView ItemsSource="{Binding Walls}"
                                 SelectionMode="Multiple"
                                 SelectedItems="{Binding FilterWalls}"
                                 HeightRequest="250">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                                <Label Text="{Binding Name}" 
                                       TextColor="Black"
                                       Padding="5"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Done"
                        BackgroundColor="Turquoise"
                        Command="{Binding ToggleWallListCommand}"/>
            </VerticalStackLayout>
        </Border>

        <!--Add Wall Pop Up -->
        <Border IsVisible="{Binding IsAddWallVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="White"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                    <Label Text="Create New Wall"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="Black"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Wall Name:" TextColor="Black" VerticalOptions="Center"/>
                        <Entry Grid.Row="0" Grid.Column="1" Placeholder="Wall name" TextColor="Black" Text="{Binding NewWallName}" />
                    </Grid>
                    <Button Text="Add Wall"
                            BackgroundColor="Turquoise"
                            Command="{Binding AddWallCommand}" />
                    <Button Text="Cancel"
                            BackgroundColor="Transparent"
                            TextColor="Gray"
                            Command="{Binding HideWallFormCommand}" />
                    <Label IsVisible="{Binding HasWallInputError}" Text="{Binding WallInputErrorMessage}" TextColor="DarkRed"></Label>
                </VerticalStackLayout>
        </Border>

        <!-- Edit Wall Pop Up -->
        <Border IsVisible="{Binding IsEditWallVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="White"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Create New Wall"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Wall Name:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedWall.Name}" TextColor="Black" Text="{Binding NewWallName}" />
                </Grid>
                <Button Text="Edit"
                        BackgroundColor="Turquoise"
                        Command="{Binding EditWallCommand}" />
                <Button Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Command="{Binding HideWallFormCommand}" />
                <Label IsVisible="{Binding HasWallInputError}" Text="{Binding WallInputErrorMessage}" TextColor="DarkRed"></Label>
            </VerticalStackLayout>
        </Border>

        <!-- Add Boulder Pop Up -->
        <Border IsVisible="{Binding IsAddBoulderVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="350"
               Padding="24"
               BackgroundColor="White"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Add Boulder"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto, Auto, Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Grade:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="e.g. 6A" TextColor="Black" Text="{Binding NewGrade}"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Style:" TextColor="Black" VerticalOptions="Center"/>
                    <Border Grid.Row="1" Grid.Column="1"
                            Stroke="Gray">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6"/>
                        </Border.StrokeShape>
                        <Picker 
                                ItemsSource="{Binding Styles}"
                                SelectedItem="{Binding NewStyle}"
                                TextColor="Black"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Text="Author:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1" Placeholder="e.g. Evžen" TextColor="Black" Text="{Binding NewAuthor}"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Built:" TextColor="Black" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="3" Grid.Column="1" TextColor="Black" Date="{Binding NewBuiltDate}"/>
                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"  Text="(Today by default)" TextColor="Gray" VerticalOptions="Center"/>

                    <Label Grid.Row="5" Grid.Column="0" Text="Retire:" TextColor="Black" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="5" Grid.Column="1" TextColor="Black" Date="{Binding NewRetireDate}"/>
                    <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="(1 month from today by default)" TextColor="Gray" VerticalOptions="Center"/>
                </Grid>
                <Button Text="Add Boulder"
                        BackgroundColor="Turquoise"
                        Command="{Binding AddBoulderCommand}"/>
                <Button Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Command="{Binding HideBoulderFormCommand}"/>
                <Label IsVisible="{Binding HasBoulderInputError}" Text="{Binding BoulderInputErrorMessage}" TextColor="DarkRed"/>
            </VerticalStackLayout>
        </Border>
        
        <!-- Edit Boulder Pop Up -->
        <Border IsVisible="{Binding IsEditBoulderVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="350"
               Padding="24"
               BackgroundColor="White"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Edit Boulder"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Grade:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedBoulder.Grade}" TextColor="Black" Text="{Binding NewGrade}"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Style:" TextColor="Black" VerticalOptions="Center"/>
                    <Border Grid.Row="1" Grid.Column="1"
                            Stroke="Gray">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6"/>
                        </Border.StrokeShape>
                        <Picker 
                            ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding NewStyle}"
                            TextColor="Black"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Text="Author:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1" Placeholder="{Binding SelectedBoulder.Author}" TextColor="Black" Text="{Binding NewAuthor}"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Built:" TextColor="Black" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="3" Grid.Column="1" TextColor="Black" Date="{Binding NewBuiltDate}"/>

                    <Label Grid.Row="4" Grid.Column="0" Text="Retire:" TextColor="Black" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="4" Grid.Column="1" TextColor="Black" Date="{Binding NewRetireDate}"/>
                </Grid>
                <Button Text="Save Changes"
                        BackgroundColor="Turquoise"
                        Command="{Binding EditBoulderCommand}"/>
                <Button Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Command="{Binding HideBoulderFormCommand}"/>
                <Label IsVisible="{Binding HasBoulderInputError}" Text="{Binding BoulderInputErrorMessage}" TextColor="DarkRed"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>