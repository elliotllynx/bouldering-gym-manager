<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BoulderSetManager.ViewModels"
             xmlns:entities="clr-namespace:BoulderSetManager.Models.Entities"
             x:Class="BoulderSetManager.Views.MainView"
             Shell.NavBarIsVisible="False"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui">

    <ContentPage.BindingContext>
        <vm:MainViewModel/>
    </ContentPage.BindingContext>

    <Grid>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto">

            <!-- Row 0: Gym Selection -->
            <HorizontalStackLayout Grid.Row="0" Padding="16,0" >
                <Button Grid.Column="0" Text="← Back"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}"/>
                <BoxView WidthRequest="1" 
                         Margin="10"
                         BackgroundColor="Gray" 
                         VerticalOptions="Fill"/>
                <Label Grid.Column="1" Text="Gym:"
                       VerticalOptions="Center"
                       Padding="10,0,0,0"/>
                <Label Grid.Column="1" Text="{Binding SelectedGym.DisplayName}"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       Padding="10,0,0,0"/>

            </HorizontalStackLayout>

            <!-- Row 1: Filtering -->
            <HorizontalStackLayout Grid.Row="1" Padding="16,0">
                <Label Text="Filter Boulders:"
                           VerticalOptions="Center"
                           Padding="15,0,15,0"/>

                <Button Text="{Binding SelectedWallsSummary}"
                        Command="{Binding ToggleWallListCommand}"
                        CornerRadius="6"
                        Margin="15,0,0,0"/>

                <Label Text="Grade:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterGrade}"
                           Placeholder="e.g. 6A"
                           WidthRequest="80"/>

                <Label Text="Style:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Picker ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding FilterStyle}"
                            WidthRequest="100"/>

                <Label Text="Author:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterAuthor}"
                           Placeholder="Author"
                           WidthRequest="100"/>

                <Label Text="Retire in &lt;= "
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                <Entry Text="{Binding FilterRetireInDays}"
                           Placeholder="days"
                           Keyboard="Numeric"
                           WidthRequest="60"/>
                <Label Text="days"
                           VerticalOptions="Center"/>

                <Button Text="Filter"
                        CornerRadius="6"
                        Margin="15,0,0,0"
                        Command="{Binding FilterCommand}"/>
                <Button Text="Reset"
                        Style="{StaticResource SecondaryButton}"
                        CornerRadius="6"
                        Margin="5,0,0,0"
                        Command="{Binding ResetFilterCommand}"/>
                <Button Text="Filter Soon Retiring Boulders"
                        Style="{StaticResource SecondaryButton}"
                        CornerRadius="6"
                        Margin="5,0,0,0"
                        Command="{Binding FilterRetiringCommand}"/>

            </HorizontalStackLayout>



            <!-- Row 2: Error Message -->
            <Label Grid.Row="2" 
                   Text="{Binding FilterErrorMessage}" 
                   Style="{StaticResource ErrorText}"
                   FontSize="12"
                   IsVisible="{Binding HasFilterError}"
                   Padding="15"/>

            <!-- Row 4: Column Annotations -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*,*,*,*,*"
                  Margin="20,5,160,3">
                <Label Grid.Column="0" Text="Grade" Style="{StaticResource GrayText}" FontSize="12"/>
                <Label Grid.Column="1" Text="Type" Style="{StaticResource GrayText}" FontSize="12"/>
                <Label Grid.Column="2" Text="Author" Style="{StaticResource GrayText}" FontSize="12"/>
                <Label Grid.Column="3" Text="Days Left" Style="{StaticResource GrayText}" FontSize="12"/>
                <Label Grid.Column="4" Text="Built" Style="{StaticResource GrayText}" FontSize="12"/>
                <Label Grid.Column="5" Text="Retire" Style="{StaticResource GrayText}" FontSize="12"/>
            </Grid>

            <!-- Row 4: Boulder List View -->
            <ScrollView Grid.Row="4"
                        VerticalScrollBarVisibility="Always">

                <!-- Following CollectionView xaml made with the help of ClaudeAI -->
                <CollectionView ItemsSource="{Binding Walls}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="entities:WallDTO">
                            <VerticalStackLayout Padding="12,8" IsVisible="{Binding IsVisible}">

                                <!-- Wall header -->
                                <Border Stroke="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource DarkAccent}}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12,12,0,0" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                                          BackgroundColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                                          Padding="12,8">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                        <Button Grid.Column="1"
                                                Text="+ Boulder"
                                                CornerRadius="6"
                                                Margin="10,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowAddBoulderCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="2"
                                                Text="Edit"
                                                Style="{StaticResource SecondaryButtonLight}"
                                                Margin="10,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowEditWallCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="3"
                                                Text="{Binding ArchiveButtonText}"
                                                BackgroundColor="{StaticResource Tertiary}"
                                                TextColor="White"
                                                CornerRadius="6"
                                                Margin="10,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ToggleArchiveWallCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="4"
                                                Text="Delete"
                                                BackgroundColor="{StaticResource Secondary}"
                                                TextColor="White"
                                                CornerRadius="6"
                                                Margin="10,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteWallCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </Border>

                                <!-- Boulder rows -->
                                <Border Stroke="Transparent"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="0,0,12,12" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Boulders}" Spacing="0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="entities:BoulderProblemDTO">
                                                <Grid ColumnDefinitions="2*,2*,2*,2*,2*,2*,0.8*,1.2*,*"
                                                      Padding="12,2"
                                                      BackgroundColor="{Binding RowBackgroundColor}"
                                                      IsVisible="{Binding IsVisible}">
                                                    <Label Grid.Column="0" Text="{Binding Grade}" />
                                                    <Label Grid.Column="1" Text="{Binding Style}" />
                                                    <Label Grid.Column="2" Text="{Binding Author}"/>
                                                    <Label Grid.Column="3" Text="{Binding DaysLeft, StringFormat='{0} days'}"/>
                                                    <Label Grid.Column="4" Text="{Binding BuiltDate, StringFormat='{0:dd.MM.yy}'}"/>
                                                    <Label Grid.Column="5" Text="{Binding RetireDate, StringFormat='{0:dd.MM.yy}'}"/>
                                                    <Border Grid.Column="6" 
                                                            HeightRequest="30"
                                                            VerticalOptions="Center"
                                                            Margin="0,0,10,0"
                                                            Stroke="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6"/>
                                                        </Border.StrokeShape>
                                                        <Label  Text="Edit"
                                                                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                                        VerticalOptions="Center"
                                                                HorizontalOptions="Center"
                                                                Padding="10,0">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowEditBoulderCommand}"
                                                                        CommandParameter="{Binding .}"/>
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </Border>
                                                    <Border Grid.Column="7" 
                                                            HeightRequest="30"
                                                            VerticalOptions="Center"
                                                            Stroke="{StaticResource Tertiary}"
                                                            Margin="0,0,10,0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6"/>
                                                        </Border.StrokeShape>
                                                        <Label  Text="{Binding ArchiveButtonText}"
                                                                TextColor="{StaticResource Tertiary}"
                                                                VerticalOptions="Center"
                                                                HorizontalOptions="Center"
                                                                Padding="10,0">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ToggleArchiveBoulderCommand}"
                                                                        CommandParameter="{Binding .}"/>
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </Border>
                                                    <Border Grid.Column="8" 
                                                            HeightRequest="30"
                                                            VerticalOptions="Center"
                                                            Stroke="{StaticResource Secondary}"
                                                            Margin="0,0,10,0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6"/>
                                                        </Border.StrokeShape>
                                                        <Label  Text="Delete"
                                                                TextColor="{StaticResource Secondary}"
                                                                VerticalOptions="Center"
                                                                HorizontalOptions="Center"
                                                                Padding="10,0">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteBoulderCommand}"
                                                                        CommandParameter="{Binding }"/>
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>


            <microcharts:ChartView Grid.Row="4"
                                   WidthRequest="100"
                                   HeightRequest="100"
                                   HorizontalOptions="End"
                                   VerticalOptions="End"
                                   Margin="12"
                                   Chart="{Binding StyleChart}"/>

            <Grid Grid.Row="5" ColumnDefinitions="*,*" >
                <HorizontalStackLayout HorizontalOptions="Start" Grid.Column="0" Padding="15,0">
                    <Label Text="Active" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding ActiveVisible}" />

                    <Label Text="Draft" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding DraftVisible}" />

                    <Label Text="Archived" VerticalOptions="Center" />
                    <CheckBox IsChecked="{Binding ArchivedVisible}" />
                </HorizontalStackLayout >
                <HorizontalStackLayout HorizontalOptions="End" Margin="20,3,20,0" Grid.Column="1">
                    <Label Text="Average Grade:"
                           VerticalOptions="Center"
                           Padding="15,0,0,0"/>
                    <Label Text="{Binding AverageGrade}"
                           FontAttributes="Bold"
                           FontSize="20"
                           VerticalOptions="Center"
                           Padding="5,0,15,0"/>
                    <BoxView Color="{StaticResource Primary}" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" Margin="5,0"/>
                    <Label Text="Slab" FontSize="12" VerticalOptions="Center"/>
                    <BoxView Color="{StaticResource Tertiary}" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"  Margin="5,0"/>
                    <Label Text="Vertical" FontSize="12" VerticalOptions="Center"/>
                    <BoxView Color="{StaticResource Secondary}" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"  Margin="5,0"/>
                    <Label Text="Overhang" FontSize="12" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- Row 6: Add wall button -->
            <Grid Grid.Row="6"
                  ColumnDefinitions="*,Auto">
                <Button Grid.Column="0"
                    Text="+ Add Wall"
                    CornerRadius="8"
                    Margin="16"
                    WidthRequest="200"
                    HorizontalOptions="Start"
                    Command="{Binding ShowAddWallCommand}"/>
                <HorizontalStackLayout
                    Grid.Column="1"
                    HorizontalOptions="End">
                    <Label Text="Mode:"
                           VerticalOptions="Center"
                           Padding="15,0"></Label>
                    <Switch Margin="0"
                        IsToggled="{Binding IsDarkMode}"/>
                </HorizontalStackLayout>
                
            </Grid>
        </Grid>

        <BoxView Color="Black"
                 Opacity="0.5"
                 IsVisible="{Binding IsPopUpVisible}" />

        <!-- Select Walls Pop Up -->
        <Border IsVisible="{Binding IsWallListExpanded}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="350"
                Padding="24"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout >
                <CollectionView ItemsSource="{Binding Walls}"
                                 SelectionMode="Multiple"
                                 SelectedItems="{Binding FilterWalls}"
                                 HeightRequest="250">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                                <Label Text="{Binding Name}"
                                       Padding="20,5"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Done"
                        Command="{Binding ToggleWallListCommand}"/>
            </VerticalStackLayout>
        </Border>

        <!--Add Wall Pop Up -->
        <Border IsVisible="{Binding IsAddWallVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                    <Label Text="Create New Wall"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Wall Name:" VerticalOptions="Center"/>
                        <Entry Grid.Row="0" Grid.Column="1" Placeholder="Wall name" Text="{Binding NewWallName}" />
                    </Grid>
                    <Button Text="Add Wall"
                            Command="{Binding AddWallCommand}" />
                    <Button Text="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding HideWallFormCommand}" />
                <Label IsVisible="{Binding HasWallInputError}"
                       Text="{Binding WallInputErrorMessage}"
                       Style="{StaticResource ErrorText}">
                </Label>
                </VerticalStackLayout>
        </Border>

        <!-- Edit Wall Pop Up -->
        <Border IsVisible="{Binding IsEditWallVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Edit Wall"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Wall Name:" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedWall.Name}" Text="{Binding NewWallName}" />
                </Grid>
                <Button Text="Edit"
                        Command="{Binding EditWallCommand}" />
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding HideWallFormCommand}" />
                <Label IsVisible="{Binding HasWallInputError}" Text="{Binding WallInputErrorMessage}" Style="{StaticResource ErrorText}"></Label>
            </VerticalStackLayout>
        </Border>

        <!-- Add Boulder Pop Up -->
        <Border IsVisible="{Binding IsAddBoulderVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="350"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Add Boulder"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto, Auto, Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Grade:" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="e.g. 6A" Text="{Binding NewGrade}"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Style:" VerticalOptions="Center"/>
                    <Border Grid.Row="1" Grid.Column="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6"/>
                        </Border.StrokeShape>
                        <Picker 
                                ItemsSource="{Binding Styles}"
                                SelectedItem="{Binding NewStyle}"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Text="Author:" VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1" Placeholder="e.g. Evžen" Text="{Binding NewAuthor}"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Built:" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="3" Grid.Column="1" Date="{Binding NewBuiltDate}"/>
                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"  Text="(Today by default)" Style="{StaticResource GrayText}" VerticalOptions="Center"/>

                    <Label Grid.Row="5" Grid.Column="0" Text="Retire:" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="5" Grid.Column="1" Date="{Binding NewRetireDate}"/>
                    <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="(1 month from today by default)" Style="{StaticResource GrayText}" VerticalOptions="Center"/>
                </Grid>
                <Button Text="Add Boulder"
                        Command="{Binding AddBoulderCommand}"/>
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding HideBoulderFormCommand}"/>
                <Label IsVisible="{Binding HasBoulderInputError}" Text="{Binding BoulderInputErrorMessage}" Style="{StaticResource ErrorText}"/>
            </VerticalStackLayout>
        </Border>
        
        <!-- Edit Boulder Pop Up -->
        <Border IsVisible="{Binding IsEditBoulderVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="350"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Edit Boulder"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Grade:" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedBoulder.Grade}" Text="{Binding NewGrade}"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Style:" VerticalOptions="Center"/>
                    <Border Grid.Row="1" Grid.Column="1"
                            Stroke="Gray">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6"/>
                        </Border.StrokeShape>
                        <Picker 
                            ItemsSource="{Binding Styles}"
                            SelectedItem="{Binding NewStyle}"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Text="Author:" VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1" Placeholder="{Binding SelectedBoulder.Author}" Text="{Binding NewAuthor}"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Built:" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="3" Grid.Column="1" Date="{Binding NewBuiltDate}"/>

                    <Label Grid.Row="4" Grid.Column="0" Text="Retire:" VerticalOptions="Center"/>
                    <DatePicker Grid.Row="4" Grid.Column="1" Date="{Binding NewRetireDate}"/>
                </Grid>
                <Button Text="Save Changes"
                        Command="{Binding EditBoulderCommand}"/>
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding HideBoulderFormCommand}"/>
                <Label IsVisible="{Binding HasBoulderInputError}" Text="{Binding BoulderInputErrorMessage}" Style="{StaticResource ErrorText}"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>