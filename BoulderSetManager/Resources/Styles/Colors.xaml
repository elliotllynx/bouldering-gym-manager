<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- constants, dont change between styles -->
    <Color x:Key="Primary">Turquoise</Color>
    <Color x:Key="PrimaryDark">Turquoise</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <Color x:Key="Warning">IndianRed</Color>
    <Color x:Key="WarningDark">Red</Color>

    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- no idea what these do -->
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="SecondaryDarkText">MediumTurquoise</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>

    <!-- cyanish purple color theme -->
    <!-- main colors -->
    <Color x:Key="Secondary">#006a72</Color>
    <Color x:Key="Tertiary">#a78bfa</Color>

    <!-- background -->
    <Color x:Key="OffBlack">#1d242f</Color>

    <!-- Buttons and Labels -->
    <Color x:Key="LightAccent">#ebeef2</Color>
    <Color x:Key="LightAccent2">#afb8c7</Color>

    <Color x:Key="DarkAccent">#101723</Color>
    <Color x:Key="DarkAccent2">#1b2433</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>

    <!-- Idk something for predefined styles -->
    <Color x:Key="Gray100">#F5F7F9</Color>
