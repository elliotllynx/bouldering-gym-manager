<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BoulderSetManager.Views.SelectGymView"
             xmlns:vm="clr-namespace:BoulderSetManager.ViewModels"
             Title="SelectGym">

    <ContentPage.BindingContext>
        <vm:SelectGymViewModel/>
    </ContentPage.BindingContext>

    <Shell.TitleColor>White</Shell.TitleColor>

    <Grid>

        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Spacing="12"
                             Margin="0,40,0,0"
                             WidthRequest="300">
            <Label Text="Select Gym:"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White" />
            <Picker ItemsSource="{Binding Gyms}"
                    SelectedItem="{Binding SelectedGym}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    TextColor="White" />
            <Button Text="Select Gym"
                    BackgroundColor="Turquoise"
                    TextColor="Black"
                    CornerRadius="8"
                    Command="{Binding SelectGymCommand}" />
            <Button Text="Delete Gym"
                    BackgroundColor="Turquoise"
                    TextColor="Black"
                    CornerRadius="8"
                    Command="{Binding DeleteGymCommand}" />
            <Button Text="Modify Gym"
                    BackgroundColor="Turquoise"
                    TextColor="Black"
                    CornerRadius="8"
                    Command="{Binding ShowModifyFormCommand}" />
            <Button Text="Create New Gym"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    CornerRadius="8"
                    Command="{Binding ShowCreateFormCommand}" />
            <Label IsVisible="{Binding HasSelectError}" Text="{Binding SelectErrorMessage}" TextColor="Red"></Label>
        </VerticalStackLayout>


        <BoxView Color="Black"
                 Opacity="0.5"
                 IsVisible="{Binding IsFormVisible}" />

        <Frame IsVisible="{Binding IsCreateFormVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               CornerRadius="12"
               BackgroundColor="White">
            <VerticalStackLayout Spacing="12">
                <Label Text="Create New Gym"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Gym Name:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="Gym name" TextColor="Black" Text="{Binding NewGymName}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Gym Location:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1" Placeholder="Location" TextColor="Black" Text="{Binding NewGymLocation}" />
                </Grid>
                <Button Text="Create Gym"
                        BackgroundColor="Turquoise"
                        Command="{Binding CreateGymCommand}" />
                <Button Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Command="{Binding HideFormCommand}" />
                <Label IsVisible="{Binding HasInputError}" Text="{Binding InputErrorMessage}" TextColor="DarkRed"></Label>
            </VerticalStackLayout>
        </Frame>

        <Frame IsVisible="{Binding IsModifyFormVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               CornerRadius="12"
               BackgroundColor="White">
            <VerticalStackLayout Spacing="12">
                <Label Text="Modify Gym"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Gym Name:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedGym.Name}" TextColor="Black" Text="{Binding NewGymName}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Gym Location:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1" Placeholder="{Binding SelectedGym.Location}" TextColor="Black" Text="{Binding NewGymLocation}" />
                </Grid>
                <Button Text="Modify Gym"
                        BackgroundColor="Turquoise"
                        Command="{Binding ModifyGymCommand}" />
                <Button Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Command="{Binding HideFormCommand}" />
                <Label IsVisible="{Binding HasInputError}" Text="{Binding InputErrorMessage}" TextColor="DarkRed"></Label>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>