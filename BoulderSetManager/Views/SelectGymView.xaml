<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BoulderSetManager.Views.SelectGymView"
             xmlns:vm="clr-namespace:BoulderSetManager.ViewModels"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:SelectGymViewModel/>
    </ContentPage.BindingContext>

    <Grid>

        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Spacing="12"
                             Margin="0,40,0,0"
                             WidthRequest="300">
            <Label Text="Select Gym:"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Picker ItemsSource="{Binding Gyms}"
                    SelectedItem="{Binding SelectedGym}"
                    ItemDisplayBinding="{Binding DisplayName}" />
            <Button Text="Select Gym"
                    CornerRadius="8"
                    Command="{Binding SelectGymCommand}" />
            <Button Text="Delete Gym"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding DeleteGymCommand}" />
            <Button Text="Modify Gym"
                    Style="{StaticResource SecondaryButton}"
                    CornerRadius="8"
                    Command="{Binding ShowModifyFormCommand}" />
            <Button Text="Create New Gym"
                    Style="{StaticResource SecondaryButton}"
                    CornerRadius="8"
                    Command="{Binding ShowCreateFormCommand}" />
            <Label IsVisible="{Binding HasSelectError}" Text="{Binding SelectErrorMessage}" Style="{StaticResource ErrorText}"></Label>
        </VerticalStackLayout>


        <BoxView Color="Black"
                 Opacity="0.5"
                 IsVisible="{Binding IsPopUpVisible}" />

        <Border IsVisible="{Binding IsCreateFormVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Create New Gym"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Gym Name:" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="Gym name"  Text="{Binding NewGymName}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Gym Location:" VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1" Placeholder="Location" Text="{Binding NewGymLocation}" />
                </Grid>
                <Button Text="Create Gym"
                        Command="{Binding CreateGymCommand}" />
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding HideFormCommand}" />
                <Label IsVisible="{Binding HasInputError}" Text="{Binding InputErrorMessage}" Style="{StaticResource ErrorText}"></Label>
            </VerticalStackLayout>
        </Border>

        <Border IsVisible="{Binding IsModifyFormVisible}"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300"
               Padding="24"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
               StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Label Text="Modify Gym"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Gym Name:" VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1" Placeholder="{Binding SelectedGym.Name}" Text="{Binding NewGymName}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Gym Location:" TextColor="Black" VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1" Placeholder="{Binding SelectedGym.Location}" Text="{Binding NewGymLocation}" />
                </Grid>
                <Button Text="Modify Gym"
                        Command="{Binding ModifyGymCommand}" />
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding HideFormCommand}" />
                <Label IsVisible="{Binding HasInputError}" Text="{Binding InputErrorMessage}" Style="{StaticResource ErrorText}"></Label>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>